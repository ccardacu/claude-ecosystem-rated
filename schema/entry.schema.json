{
  "$id": "https://github.com/claude-ecosystem-rated/claude-ecosystem-rated/schema/entry.schema.json",
  "title": "Claude Ecosystem Rated Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "url",
    "category",
    "description",
    "ratings",
    "evidence",
    "compatibleClients",
    "lastVerified",
    "submittedBy"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Unique slug; must match the filename (data/entries/{id}.json)."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "repo": {
      "type": "string",
      "format": "uri",
      "description": "Optional GitHub repository URL."
    },
    "category": {
      "type": "string",
      "enum": [
        "mcp-server",
        "agent-skill",
        "cursor-rule",
        "hook",
        "plugin",
        "cli",
        "other"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "ratings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "documentation",
        "maintenance",
        "utility",
        "trust"
      ],
      "properties": {
        "documentation": { "$ref": "#/$defs/ratingScore" },
        "maintenance": { "$ref": "#/$defs/ratingScore" },
        "utility": { "$ref": "#/$defs/ratingScore" },
        "trust": { "$ref": "#/$defs/ratingScore" }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "compatibleClients": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "claude-code",
          "cursor",
          "claude-desktop",
          "windsurf"
        ]
      }
    },
    "lastVerified": {
      "type": "string",
      "format": "date",
      "description": "ISO date when ratings were last verified."
    },
    "submittedBy": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,37}[a-zA-Z0-9])?$",
      "description": "GitHub username of the contributor who submitted or last verified the entry."
    },
    "maintainerDisclosure": {
      "type": "boolean",
      "description": "Set to true if the submitter maintains the rated tool."
    }
  },
  "$defs": {
    "ratingScore": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    }
  }
}
